# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jeepneywaze
POSTGRES_USER=jeepney
POSTGRES_PASSWORD=jeepney_dev_pass

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MQTT (Mosquitto) ────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=jeepney
MQTT_PASSWORD=mqtt_dev_pass

# ─── Kafka ───────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_GPS_PINGS=gps.pings
KAFKA_TOPIC_BEACONS=beacons.detected

# ─── API Service ─────────────────────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# ─── GPS Ingestion (Go) ──────────────────────────────────
INGESTION_PORT=8080

# ─── Beacon Engine (Python) ──────────────────────────────
BEACON_ENGINE_PORT=8001
DBSCAN_EPS=0.0003          # ~30m radius in degrees
DBSCAN_MIN_SAMPLES=3       # min 3 users to form a beacon
KALMAN_PROCESS_NOISE=0.01
JEEPNEY_MIN_SPEED_KMH=3
JEEPNEY_MAX_SPEED_KMH=60
STOP_MATCH_RADIUS_M=40

# ─── FCM (Push Notifications) ────────────────────────────
FCM_SERVER_KEY=your-fcm-server-key

# ─── PAGASA (Baha Mode — Phase 1 optional) ───────────────
PAGASA_API_KEY=your-pagasa-api-key
